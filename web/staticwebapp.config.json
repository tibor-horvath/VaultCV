{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.ico",
      "/*.png",
      "/*.svg"
    ]
  },
  "routes": [
    {
      "route": "/admin/*",
      "methods": [
        "post",
        "get"
      ],
      "allowedRoles": [
        "admin"
      ]
    },
    {
      "route": "/api/manage/*",
      "methods": [
        "post",
        "get",
        "put",
        "delete",
        "patch",
        "options"
      ],
      "allowedRoles": [
        "admin"
      ]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin",
      "statusCode": 302
    },
    "403": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin",
      "statusCode": 302
    }
  },
  "platform": {
    "apiRuntime": "node:22"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "no-referrer",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: blob: https://*.blob.core.windows.net; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://*.blob.core.windows.net"
  }
}